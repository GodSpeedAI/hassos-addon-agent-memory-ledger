# Stage 1: Build ruvector-postgres on Debian (matching upstream build environment)
# hadolint ignore=DL3007
FROM rust:1.85-bookworm-slim AS builder
ARG VERSION
ARG TARGETARCH
ARG TARGETVARIANT

# hadolint ignore=DL3008
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    libssl-dev \
    pkg-config \
    clang \
    libclang-dev \
    flex \
    bison \
    curl \
    ca-certificates \
    gnupg \
    git \
    && rm -rf /var/lib/apt/lists/*

# Add PostgreSQL 17 from PGDG
# hadolint ignore=DL3008,DL4006
RUN curl -fsSL https://www.postgresql.org/media/keys/ACCC4CF8.asc \
    | gpg --dearmor -o /usr/share/keyrings/postgresql-keyring.gpg \
    && echo "deb [signed-by=/usr/share/keyrings/postgresql-keyring.gpg] http://apt.postgresql.org/pub/repos/apt bookworm-pgdg main" \
    > /etc/apt/sources.list.d/pgdg.list \
    && apt-get update && apt-get install -y --no-install-recommends \
    postgresql-server-dev-17 \
    && rm -rf /var/lib/apt/lists/*

# Install cargo-pgrx
RUN cargo install cargo-pgrx --version 0.12.9 --locked

WORKDIR /workspace

# Clone and checkout the specific version
RUN git clone https://github.com/ruvnet/RuVector.git . \
    && git checkout "v${VERSION}"

# Initialize pgrx with system PostgreSQL 17
RUN cargo pgrx init --pg17=/usr/lib/postgresql/17/bin/pg_config

# Build only the ruvector-postgres crate with pg17 features
WORKDIR /workspace/crates/ruvector-postgres
RUN cargo pgrx package --features "pg17 index-all"

# Stage 2: Copy built extension into TimescaleDB Alpine image
FROM timescale/timescaledb:latest-pg17

# Copy the built .so and extension files from the Debian builder
COPY --from=builder /workspace/target/release/ruvector-pg17/usr/lib/postgresql/17/lib/ruvector*.so /usr/local/lib/postgresql/
COPY --from=builder /workspace/target/release/ruvector-pg17/usr/share/postgresql/17/extension/ruvector* /usr/local/share/postgresql/extension/

# Labels
LABEL \
    org.opencontainers.image.source="https://github.com/GodSpeedAI/hassos-addon-agent-memory-ledger"
